{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "dist-ts",
        "rootDir": "src",
        "strict": true,
        "declaration": false,
        "sourceMap": false
    },
    "include": ["src/**/*.mts", "src/**/*.d.ts"],
    "exclude": ["node_modules", "build", "dist-ts"]
}
